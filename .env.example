# ===== Общие =====
LOG_LEVEL=INFO
COMPOSE_PROFILES=cpu          # cpu | gpu — какой filter-service поднимать по умолчанию

# ===== Gateway =====
GATEWAY_PORT=8000
MAX_FILE_SIZE_MB=20
CHUNK_MAX_CHARS=3000           # размер чанка текста, отправляемого в filter-service
CHUNK_OVERLAP_CHARS=250        # нахлёст между чанками, чтобы не резать сущности пополам
FILTER_REQUEST_TIMEOUT=60      # сек, таймаут ожидания ответа от filter-service

# Внешний OpenAI-совместимый провайдер (любой: OpenAI, локальный мок, vLLM и т.д.)
EXTERNAL_LLM_BASE_URL=https://api.openai.com/v1
EXTERNAL_LLM_API_KEY=sk-changeme

# ===== Filter Service =====
FILTER_SERVICE_URL=http://filter-service:8001
FILTER_MODEL_PATH=/models/qwen2.5-7b-instruct-q4_k_m.gguf
FILTER_MODEL_CTX=8192
FILTER_MODEL_THREADS=8
FILTER_MODEL_BATCH=512          # размер батча prompt-eval, можно повысить до 1024 на 8+ ядрах
FILTER_MODEL_MAX_TOKENS=1024    # доп. предохранитель длины генерации (grammar останавливает раньше)
FILTER_SERVICE_PORT=8001
FILTER_MODEL_VERBOSE=false      # true — для разовой диагностики скорости prompt-eval/generation

# GBNF-grammar даёт формальную гарантию валидного JSON, но на моделях
# с большим словарём (Qwen2.5 ~152k токенов) добавляет ~120-150 мс к КАЖДОМУ
# генерируемому токену (проверка допустимости по всему словарю на каждом шаге) —
# на практике это давало 15-27 сек на короткий чанк. По умолчанию выключено:
# используется сильный few-shot промпт + мягкий JSON-repair на выходе.
# Установите true, чтобы включить обратно (для сравнения/демонстрации).
FILTER_USE_GRAMMAR=false

N_GPU_LAYERS=30